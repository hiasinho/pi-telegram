{
  "name": "pi-telegram",
  "version": "0.1.0",
  "private": false,
  "description": "Telegram DM bridge extension for pi",
  "type": "module",
  "keywords": ["pi-package", "pi", "telegram", "bot", "extension"],
  "scripts": {
    "check": "npm exec --yes --package esbuild -- esbuild index.ts --format=esm --platform=node --target=node22 --packages=external --outfile=/tmp/pi-telegram-index-check.mjs",
    "test": "npm exec --yes --package esbuild -- esbuild tests/commands.test.ts --bundle --format=esm --platform=node --target=node22 --packages=external --outfile=/tmp/pi-telegram-commands.test.mjs && node --test /tmp/pi-telegram-commands.test.mjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hiasinho/pi-telegram.git"
  },
  "homepage": "https://github.com/hiasinho/pi-telegram",
  "bugs": {
    "url": "https://github.com/hiasinho/pi-telegram/issues"
  },
  "pi": {
    "extensions": ["./index.ts"],
    "skills": ["./skills"]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  }
}
